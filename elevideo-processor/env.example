# ─────────────────────────────────────────────
# Cloudinary
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Directorio local para archivos temporales de procesamiento
CLOUDINARY_TEMP_DIR=/tmp/video_processing

# ─────────────────────────────────────────────
# Autenticación
# ─────────────────────────────────────────────
# Secret HS256 compartido con Spring Boot (jwt.secret en Spring)
SERVICE_JWT_SECRET=change_me_in_production

# API key interna para comunicación entre servicios
SERVICE_API_KEY=change_me_in_production

# ─────────────────────────────────────────────
# Webhooks hacia Spring Boot
# ─────────────────────────────────────────────
# Notificaciones finales (completado / fallido / cancelado)
SPRING_BOOT_WEBHOOK_URL=https://your-api.com/api/internal/processing-jobs/webhook

# Notificaciones de progreso en tiempo real (best-effort)
SPRING_BOOT_PROGRESS_WEBHOOK_URL=https://your-api.com/api/webhook/progress

# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Activar reload automático (solo desarrollo)
RELOAD=true

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
